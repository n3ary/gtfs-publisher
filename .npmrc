# n3ary/gtfs workspace — most @n3ary/* deps are workspace-local
# (see package.json `workspaces`). This .npmrc exists so non-workspace
# @n3ary deps (e.g. the published adapter packages from gtfs-adapters)
# resolve to GH Packages in CI/dev. Auth token is NOT here — CI passes
# NODE_AUTH_TOKEN via a HOME-scoped .npmrc built in the workflow
# steps. Never commit a _authToken line to this file (the same reasoning
# as gtfs-adapters/ and cluj-napoca-gtfs-adapter/).
@n3ary:registry=https://npm.pkg.github.com
