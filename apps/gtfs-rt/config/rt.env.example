# rt.env — environment for the neary-gtfs-rt systemd unit.
#
# Install on the host at /etc/neary-gtfs/rt.env (mode 0640,
# owner neary-gtfs:neary-gtfs). The systemd unit reads this via
# `EnvironmentFile=` and podman re-reads it via `--env-file`
# inside ExecStart.
#
# See install.sh for the full bootstrap.

# URL of the feeds.json registry published by the static pipeline.
FEEDS_JSON=https://gtfs.n3ary.com/feeds.json

# Listen port. The systemd unit maps host port 80 -> this port
# (via podman -p 80:8080), so this is the in-container port only.
# Host traffic from Cloudflare hits :80 on the host and is forwarded
# to :8080 inside the container. Keep this at 8080 unless you also
# edit the -p flag in neary-gtfs-rt.service.
PORT=8080

# Per-feed poll cadence (ms). 15 s is the default — long enough
# to not hammer upstreams, short enough that a missed poll
# shows up quickly.
POLL_INTERVAL_MS=15000

# Per-fetch timeout (ms). 10 s covers a slow upstream without
# making a wedged feed appear "down" too quickly.
UPSTREAM_TIMEOUT_MS=10000

# Comma-separated feed IDs to enable. Empty (or omitted) means
# all feeds in the registry.
ENABLED_FEEDS=cluj-napoca

# fastify / pino log level. In production, `info` is plenty;
# switch to `debug` if you're chasing an upstream-quirk regression.
LOG_LEVEL=info
