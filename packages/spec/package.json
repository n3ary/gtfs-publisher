{
  "name": "@neary-gtfs/spec",
  "version": "0.1.0",
  "private": true,
  "description": "GTFS spec — the canonical contract. Two subpaths: /spec (per-spec-file readers) and /schema (registry-publication shapes). Zero per-feed knowledge.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./spec": {
      "types": "./dist/spec/index.d.ts",
      "import": "./dist/spec/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest --run --passWithNoTests",
    "lint": "echo 'no lint yet' && exit 0"
  },
  "dependencies": {
    "csv-parse": "^7.0.1",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  }
}